# ================================
# Stony Brook AI Assistant Platform
# ================================

# Database
DATABASE_URL=postgresql+asyncpg://sbu_user:sbu_pass@postgres:5432/sbu_assistant
DATABASE_URL_SYNC=postgresql://sbu_user:sbu_pass@postgres:5432/sbu_assistant
POSTGRES_USER=sbu_user
POSTGRES_PASSWORD=sbu_pass
POSTGRES_DB=sbu_assistant

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string
ADMIN_DEFAULT_EMAIL=admin@stonybrook.edu
ADMIN_DEFAULT_PASSWORD=admin123

# AI Provider: "mock", "local", "openai", or "bedrock"
# Use "local" for fully offline RAG — no API key required
AI_PROVIDER=mock

# Local AI — Ollama (LLM) + fastembed (embeddings), no API key needed
# Install Ollama: brew install ollama && ollama serve && ollama pull llama3.2
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# OpenAI (when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AWS Bedrock (when AI_PROVIDER=bedrock)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Storage: "local" or "s3"
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/data/storage
S3_BUCKET=sbu-assistant-docs
S3_REGION=us-east-1
S3_ENDPOINT_URL=

# MinIO (local S3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# App
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
